# CurseForge packager configuration.
# Docs: https://support.curseforge.com/en/support/solutions/articles/9000197281

# Use CHANGELOG.md as the release notes source instead of auto-generated
# git log output. Without this line, the packager falls back to listing
# raw git commits, which exposes committer email addresses and clutters
# the CurseForge changelog page.
manual-changelog: CHANGELOG.md

# Use the existing MIT LICENSE file as the packager's license reference
# rather than having it auto-generate a default one.
license-output: LICENSE

# Files and directories excluded from the built zip. Git-ignored files
# are already excluded by default, but this is belt-and-suspenders for
# anything that might slip through. ROADMAP.md is intentionally NOT
# listed here -- it ships in the user zip as a visible project roadmap
# per the 2026-04-22 session decision.
ignore:
    - HANDOFF.md
    - .gitignore
    - .pkgmeta
